# Copy this file to .env and fill in your own values. Never commit .env.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Model is read from here at startup so it can be repinned without touching code.
# gemini-2.0-flash was shut down, so pin to a model you've confirmed is live.
#
# This is real financial analysis (SIP amounts, insurance gaps, debt payoff
# order) feeding real decisions — on a paid tier, prioritize accuracy and
# reliability over free-tier quota conservation. gemini-2.5-pro is Google's
# strongest reasoning model; use it for BOTH FinanceAgent (the analysis) and
# the orchestrator (the cross-agent merge/final verdict — GEMINI_MODEL powers
# both, see agents/finance_agent.py and agents/orchestrator.py).
#
# Staying on the free tier? Cheaper, faster options that were confirmed
# available there: gemini-flash-lite-latest, gemini-2.5-flash-lite,
# gemini-flash-latest — trade some analysis depth for a larger free-tier
# request budget.
GEMINI_MODEL=gemini-2.5-pro

# ResearchAgent needs a GROUNDING-capable model for Google Search — this feeds
# a real investment decision too, so it gets the same accuracy-first model by
# default. Kept as its own env var so it CAN be repinned independently (e.g.
# to a cheaper grounding-capable model) without touching FinanceAgent's.
RESEARCH_MODEL=gemini-2.5-pro

# If the primary model 503s ("high demand") this many times IN A ROW during a
# turn, the harness auto-switches the affected agent(s) to the fallback model
# below for the rest of that turn, then reverts for the next turn (see
# harness/agent_runner.py). Set to 0 to disable.
PB_MODEL_FALLBACK_AFTER=2

# Fallback models — deliberately still flagship Flash, NOT Flash-Lite, so an
# occasional 503 never trades away analysis quality, only some depth/speed.
# Pinned (not "-latest") on purpose: an alias can resolve to the very release
# that's overloaded, so a pinned version is more likely a genuinely different
# serving path. GEMINI_MODEL_FALLBACK covers the orchestrator + FinanceAgent;
# RESEARCH_MODEL_FALLBACK must stay grounding-capable.
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
RESEARCH_MODEL_FALLBACK=gemini-2.5-flash

# Per-attempt call timeout (layer 2). gemini-2.5-pro reasons more, and this
# turn's tool-calling loop can run several rounds, so it routinely needs well
# over a flash model's ~10-20s per call. 60s (tuned for flash) cut Pro off
# mid-response on every attempt in practice — 150s gives a full analysis room
# to actually finish on the first try. Lower this back down if you repin to a
# flash/flash-lite model.
PB_HARNESS_TIMEOUT=150

# Set PB_SEARCH_CACHE=0 to disable the research cache-on-success (force a genuinely
# live search — e.g. when you want a fresh result on camera).
PB_SEARCH_CACHE=1

# Client-side pacing between our own outgoing model calls (flash-lite variants
# are auto-doubled — see harness/throttle.py). 60 is a generous default for a
# typical pay-as-you-go tier; the old free-tier cap needed ~12. If you know
# your tier's actual per-minute limit, set this a bit under it. If you don't
# and start seeing 429s, turn it down — the harness backs those off
# automatically either way, this just avoids triggering them in the first place.
PB_MAX_RPM=60

# When a 429 DOES slip through, the harness backs off this many seconds
# (exponential + jitter), honoring the server's suggested retry delay, capped
# at PB_HARNESS_RL_BACKOFF_MAX. Longer than the ordinary retry backoff because
# a 429 means a whole per-minute window is full.
PB_HARNESS_RL_BACKOFF=8
PB_HARNESS_RL_BACKOFF_MAX=45

# Gradio UI's read timeout (seconds) for its /chat call to the API. A
# cross-agent turn can chain several harness attempts + rate-limit backoffs —
# up to 4 attempts * PB_HARNESS_TIMEOUT (150s Pro-tuned) plus backoffs — so
# this must comfortably exceed that or a slow-but-healthy Pro-model turn gets
# shown to the user as an API-unreachable error.
PB_UI_READ_TIMEOUT_S=600
