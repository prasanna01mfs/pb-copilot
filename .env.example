# Copy this file to .env and fill in your own values. Never commit .env.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Model is read from here at startup so it can be repinned without touching code.
# gemini-2.0-flash was shut down; we use a "-latest" alias so the model can't go
# stale. Flash-Lite has a larger free-tier request budget than the flagship
# Flash — better for this multi-agent app (a single turn spends ~5 model calls),
# and each model has its OWN free-tier quota bucket. Options confirmed available
# on the free tier: gemini-flash-lite-latest, gemini-2.5-flash-lite,
# gemini-flash-latest (flagship, smaller free quota).
GEMINI_MODEL=gemini-flash-lite-latest

# ResearchAgent needs a GROUNDING-capable model for Google Search. Kept separate
# so (a) grounding is reliable and (b) research calls land on a different
# free-tier quota bucket than the lite model above. Override if needed.
RESEARCH_MODEL=gemini-flash-latest

# Set PB_SEARCH_CACHE=0 to disable the research cache-on-success (force a genuinely
# live search — e.g. when you want a fresh result on camera).
PB_SEARCH_CACHE=1

# Client-side rate limit: max requests/minute for the flagship/flash bucket
# (flash-lite is auto-doubled). Kept a few under the free-tier cap so our own
# call volume never trips a 429. Raise it on a paid tier for faster turns.
PB_MAX_RPM=12

# When a 429 DOES slip through, the harness backs off this many seconds
# (exponential + jitter), honoring the server's suggested retry delay, capped
# at PB_HARNESS_RL_BACKOFF_MAX. Longer than the ordinary retry backoff because
# a 429 means a whole per-minute window is full.
PB_HARNESS_RL_BACKOFF=8
PB_HARNESS_RL_BACKOFF_MAX=45
